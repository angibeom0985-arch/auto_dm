datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  name         String
  role         String       @default("USER") // USER | ADMIN
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  automations  Automation[]
  accounts     Account[]
  leads        Lead[]
  eventLogs    EventLog[]
  templates    Template[]
  queueItems   QueueItem[]
}

model Account {
  id              String    @id @default(uuid())
  instagramId     String    @unique
  username        String
  accessToken     String
  tokenExpires    DateTime?
  dailyLimit      Int       @default(150)
  notificationUrl String?
  connectedAt     DateTime  @default(now())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
}

model Automation {
  id           String      @id @default(uuid())
  name         String
  triggerType  String      // "comment" | "dm"
  trigger      String
  message      String
  status       String      @default("운영중") // "운영중" | "점검"
  targetPostId String?
  sent         Int         @default(0)
  conversion   String      @default("0%")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  queueItems   QueueItem[]
}

model Lead {
  id            String   @id @default(uuid())
  username      String   @unique
  lastActive    String
  messagesCount Int      @default(1)
  status        String   @default("대기") // "대기" | "상담중" | "전환완료"
  source        String   // "댓글" | "DM"
  lastMessage   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
}

model EventLog {
  id        String   @id @default(uuid())
  time      String
  type      String
  text      String
  status    String   // "success" | "warning" | "info" | "error"
  eventId   String   @unique
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Template {
  id        String   @id @default(uuid())
  name      String
  content   String
  type      String   @default("일반 안내")
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model QueueItem {
  id           String      @id @default(uuid())
  recipientId  String
  automationId String
  body         String
  status       String      @default("PENDING") // "PENDING" | "PROCESSING" | "COMPLETED" | "FAILED"
  retryCount   Int         @default(0)
  errorLog     String?
  createdAt    DateTime    @default(now())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  automation   Automation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
}
